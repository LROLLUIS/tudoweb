# Contadores para as respostas
excelente = 0
ruim = 0

print("--- Pesquisa de Satisfação TudoWeb ---")

# Para o teste de validação, utilizaremos 10 entrevistados.
# Para a pesquisa oficial, basta alterar o range para (1, 11).
for i in range(1, 11):
    print(f"\nEntrevistado nº {i}")
    
    # Coleta de dados
    nome = input("Digite o nome: ")
    idade = input("Digite a idade: ")
    
    print("Informe sua opinião sobre o nosso atendimento:")
    print("1: EXCELENTE | 2: BOM | 3: RUIM")
    
    opiniao = input("Sua resposta: ")

    # Estrutura de decisão para contagem
    if opiniao == "1":
        excelente += 1
    elif opiniao == "3":
        ruim += 1
    # Caso seja "2" (BOM), o programa apenas segue sem incrementar esses contadores

# Exibição dos resultados finais
print("\n" + "="*30)
print("RESUMO DA PESQUISA")
print(f"Quantidade de respostas EXCELENTE: {excelente}")
print(f"Quantidade de respostas RUIM: {ruim}")
print("="*30)



			
			
		